{
  "name": "kojori-bus-time-app",
  "main": "expo-router/entry",
  "version": "2026.5.15",
  "scripts": {
    "start": "NODE_ENV=development expo start",
    "dev": "NODE_ENV=development expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "NODE_ENV=development expo run:android",
    "android:clean": "cd android && ./gradlew clean",
    "android:bundle": "NODE_ENV=production sh -c 'cd android && ./gradlew bundleRelease'",
    "android:apk": "NODE_ENV=development sh -c 'cd android && ./gradlew assembleDebug'",
    "android:apk:release": "NODE_ENV=production sh -c 'cd android && ./gradlew assembleRelease'",
    "ios": "NODE_ENV=development expo run:ios",
    "web": "NODE_ENV=development expo start --web",
    "bake:ttc": "bun scripts/bake-ttc.ts",
    "i18n:check": "bun scripts/check-i18n-parity.ts",
    "lint": "NODE_ENV=development expo lint",
    "typecheck": "NODE_ENV=development tsc --noEmit",
    "release:android:preflight": "NODE_ENV=production bun run lint && NODE_ENV=production bun run typecheck && NODE_ENV=production bun run release:android:doctor",
    "release:android:build": "NODE_ENV=production bunx eas build --platform android --profile production",
    "release:android:build:apk": "NODE_ENV=production bunx eas build --platform android --profile production-apk",
    "release:android:submit": "NODE_ENV=production bunx eas submit --platform android --profile production",
    "release:android:doctor": "NODE_ENV=production node ./scripts/release-android-doctor.js",
    "release": "bun scripts/release.ts",
    "release:revert": "sh -c 'TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo \"no-tag\"); if [ \"$TAG\" = \"no-tag\" ]; then echo \"No tags found\"; exit 1; fi; echo \"Reverting release $TAG\"; gh release delete \"$TAG\" --yes && git tag -d \"$TAG\" && git push origin \":refs/tags/$TAG\"'"
  },
  "dependencies": {
    "@expo/ui": "~55.0.16",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.18",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.100.10",
    "dayjs": "^1.11.20",
    "expo": "~55.0.24",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.34",
    "expo-device": "~55.0.17",
    "expo-font": "~55.0.7",
    "expo-glass-effect": "~55.0.11",
    "expo-image": "~55.0.10",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.14",
    "expo-location": "~55.1.10",
    "expo-router": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.8",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.22",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-maps": "1.27.2",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "eslint": "^10.4.0",
    "eslint-config-expo": "~55.0.1",
    "typescript": "~5.9.3"
  },
  "private": true
}

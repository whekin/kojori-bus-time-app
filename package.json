    "ios": "NODE_ENV=development expo run:ios",
    "web": "NODE_ENV=development expo start --web",
    "lint": "NODE_ENV=development expo lint",
    "typecheck": "NODE_ENV=development tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.2.2",
    "@tanstack/react-query": "^5.99.0",
    "dayjs": "^1.11.20",
    "expo": "~55.0.14",
    "expo-constants": "~55.0.13",
    "expo-dev-client": "~55.0.27",
    "expo-device": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-image": "~55.0.8",
    "expo-linking": "~55.0.12",
    "expo-location": "~55.1.8",

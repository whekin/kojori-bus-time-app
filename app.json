{
  "expo": {
    "name": "Kojoring Time",
    "slug": "kojori-bus-time",
    "version": "2026.4.15",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kojoribs",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.whekin.kojoribus",
      "buildNumber": "2026041500",
      "supportsTablet": false
    },
    "android": {
      "package": "com.whekin.kojoribus",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "allowBackup": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#09090B",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "versionCode": 2026041500,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Kojoring Time to suggest whether you're closer to Kojori or Tbilisi."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#09090B",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 128
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b3dd5ad4-f12e-4c00-a17e-33f830ee23c2"
      }
    },
    "owner": "whekin"
  }
}

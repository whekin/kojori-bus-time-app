<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_body"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_surface"
  android:orientation="vertical"
  android:paddingStart="14dp"
  android:paddingEnd="14dp"
  android:paddingBottom="12dp"
  android:paddingTop="14dp">

  <!-- Direction toggles live outside the list so they stay pinned and are
       never overlapped by list scroll effects. -->
  <LinearLayout
    android:id="@+id/toggle_row_h"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:baselineAligned="false"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/toggle_kojori"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginEnd="6dp"
      android:background="@drawable/widget_chip_idle"
      android:gravity="center"
      android:paddingHorizontal="8dp"
      android:paddingVertical="5dp"
      android:text="to Kojori"
      android:textColor="@color/widget_text_dim"
      android:textSize="11sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/toggle_tbilisi"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:background="@drawable/widget_chip_idle"
      android:gravity="center"
      android:paddingHorizontal="8dp"
      android:paddingVertical="5dp"
      android:text="to Tbilisi"
      android:textColor="@color/widget_text_dim"
      android:textSize="11sp"
      android:textStyle="bold" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/toggle_row_v"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:orientation="vertical"
    android:visibility="gone">

    <TextView
      android:id="@+id/toggle_kojori_v"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="4dp"
      android:background="@drawable/widget_chip_idle"
      android:gravity="center"
      android:paddingHorizontal="8dp"
      android:paddingVertical="5dp"
      android:text="to Kojori"
      android:textColor="@color/widget_text_dim"
      android:textSize="11sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/toggle_tbilisi_v"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@drawable/widget_chip_idle"
      android:gravity="center"
      android:paddingHorizontal="8dp"
      android:paddingVertical="5dp"
      android:text="to Tbilisi"
      android:textColor="@color/widget_text_dim"
      android:textSize="11sp"
      android:textStyle="bold" />
  </LinearLayout>

  <TextView
    android:id="@+id/widget_message"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:text="No widget snapshot yet"
    android:textColor="@color/widget_text_dim"
    android:textSize="12sp"
    android:visibility="gone" />

  <ListView
    android:id="@+id/widget_list"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:divider="@null"
    android:dividerHeight="0dp"
    android:requiresFadingEdge="none"
    android:fadingEdgeLength="0dp"
    android:overScrollMode="never"
    android:scrollbars="none" />

</LinearLayout>

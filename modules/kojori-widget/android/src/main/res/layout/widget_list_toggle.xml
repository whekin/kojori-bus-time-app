<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginTop="4dp"
  android:layout_marginBottom="8dp"
  android:orientation="vertical">

  <LinearLayout
    android:id="@+id/toggle_row_h"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/toggle_kojori"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginEnd="6dp"
      android:background="@drawable/widget_chip_idle"
      android:gravity="center"
      android:paddingHorizontal="8dp"
      android:paddingVertical="5dp"
      android:text="Kojori"
      android:textColor="@color/widget_text_dim"
      android:textSize="11sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/toggle_tbilisi"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:background="@drawable/widget_chip_idle"
      android:gravity="center"
      android:paddingHorizontal="8dp"
      android:paddingVertical="5dp"
      android:text="Tbilisi"
      android:textColor="@color/widget_text_dim"
      android:textSize="11sp"
      android:textStyle="bold" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/toggle_row_v"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone">

    <TextView
      android:id="@+id/toggle_kojori_v"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="4dp"
      android:background="@drawable/widget_chip_idle"
      android:gravity="center"
      android:paddingHorizontal="8dp"
      android:paddingVertical="5dp"
      android:text="→ Kojori"
      android:textColor="@color/widget_text_dim"
      android:textSize="11sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/toggle_tbilisi_v"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@drawable/widget_chip_idle"
      android:gravity="center"
      android:paddingHorizontal="8dp"
      android:paddingVertical="5dp"
      android:text="→ Tbilisi"
      android:textColor="@color/widget_text_dim"
      android:textSize="11sp"
      android:textStyle="bold" />
  </LinearLayout>
</LinearLayout>
